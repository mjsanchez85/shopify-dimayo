{% comment %}
  DIMAYO — Especificaciones técnicas (PDP). Reemplaza a los tabs
  colapsables dentro del panel de compra (PRD 6, fila 13): Origen,
  Material e Información viven acá para que la ficha de producto
  quede más limpia. Grilla de columnas en desktop, accordion nativo
  (<details>) en mobile — mismo criterio que el resto del sitio.
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width dimayo-tech-specs">
    {%- if section.settings.heading != blank -%}
      <h2 class="h2 dimayo-tech-specs__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="dimayo-tech-specs__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'spec' -%}
          <div class="dimayo-tech-specs__col" {{ block.shopify_attributes }}>
            <h3 class="dimayo-tech-specs__col-heading">{{ block.settings.heading }}</h3>
            <div class="dimayo-tech-specs__col-content">{{ block.settings.content }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="dimayo-tech-specs__accordion">
      {%- for block in section.blocks -%}
        {%- if block.type == 'spec' -%}
          <details class="dimayo-tech-specs__item" {{ block.shopify_attributes }}>
            <summary class="dimayo-tech-specs__summary">
              {{ block.settings.heading }}
              <span class="svg-wrapper dimayo-tech-specs__chevron">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </summary>
            <div class="dimayo-tech-specs__col-content">{{ block.settings.content }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Especificaciones técnicas",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Encabezado",
      "default": "Especificaciones Técnicas"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Columna",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título",
          "default": "Origen"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Contenido",
          "default": "<p>Detalle acá.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Especificaciones técnicas",
      "blocks": [
        { "type": "spec" },
        { "type": "spec" },
        { "type": "spec" }
      ]
    }
  ]
}
{% endschema %}
