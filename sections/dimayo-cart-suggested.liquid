{% comment %}
  DIMAYO — "Sumá a tu selección" (Dimayo-PRD.md, sección 8, fila 6).
  Sección custom: related-products.liquid no aplica en /cart porque no hay
  `product` en contexto. Máximo 2 productos, botón ghost (Lacquer ya está
  asignado en esta vista al botón "Continuar a Pagar").
  Reusa el patrón <product-form> + data-type="add-to-cart-form" que Dawn
  ya cablea globalmente (product-form.js), sin JS propio.
{% endcomment %}

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- assign suggested_blocks = section.blocks | where: 'type', 'product' -%}

{%- if cart != empty and suggested_blocks.size > 0 -%}
  <div class="dimayo-cart-suggested color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
    <div class="page-width">
      <h2 class="h3 dimayo-cart-suggested__title">{{ section.settings.heading }}</h2>
      <p class="dimayo-cart-suggested__sub">{{ section.settings.subheading }}</p>

      <div class="dimayo-cart-suggested__grid">
        {%- for block in suggested_blocks -%}
          {%- assign suggested_product = block.settings.product -%}
          {%- if suggested_product != blank -%}
            <div class="dimayo-cart-suggested__card" {{ block.shopify_attributes }}>
              <a href="{{ suggested_product.url }}">
                {{
                  suggested_product.featured_image
                  | image_url: width: 200
                  | image_tag: class: 'dimayo-cart-suggested__image', widths: '88,150,200'
                }}
              </a>
              <div>
                <p class="dimayo-cart-suggested__name">
                  <a href="{{ suggested_product.url }}">{{ suggested_product.title }}</a>
                </p>
                <p class="dimayo-cart-suggested__price">
                  {{- suggested_product.price | money -}}
                </p>
                <product-form>
                  {%- form 'product',
                    suggested_product,
                    id: 'dimayo-cart-suggested-form-' | append: block.id,
                    novalidate: 'novalidate',
                    data-type: 'add-to-cart-form'
                  -%}
                    <input
                      type="hidden"
                      name="id"
                      value="{{ suggested_product.selected_or_first_available_variant.id }}"
                    >
                    <button
                      type="submit"
                      name="add"
                      class="dimayo-ghost-btn"
                      {% if suggested_product.selected_or_first_available_variant.available == false %}
                        disabled
                      {% endif %}
                    >
                      {%- if suggested_product.selected_or_first_available_variant.available == false -%}
                        {{ 'products.product.sold_out' | t }}
                      {%- else -%}
                        {{ 'products.product.add_to_cart' | t }}
                      {%- endif -%}
                    </button>
                  {%- endform -%}
                </product-form>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "DIMAYO — Sugerido de carrito",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Encabezado",
      "default": "Sumá a tu selección"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Línea de contexto",
      "default": "Pensado para acompañar lo que ya elegiste."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Producto sugerido",
      "limit": 2,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Producto"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DIMAYO — Sugerido de carrito",
      "blocks": [
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
