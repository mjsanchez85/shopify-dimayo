{% comment %}
  DIMAYO — Collage de fotos de producto (PDP). Con 1 sola imagen es un
  banner full-width (21:9). Con 2 o más, es un carrusel tipo "peek" que
  se desliza con touch/swipe (nativo del overflow-x) y también con click
  + arrastre de mouse en desktop, vía dimayo-collage-drag.js — sin
  flechas, a pedido explícito. Sin gradientes decorativos: el
  placeholder sin foto es un rectángulo Panel liso con el nombre del
  bloque en Bricolage Grotesque (PRD 2.4).
{% endcomment %}

<script src="{{ 'dimayo-collage-drag.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign cell_blocks = section.blocks | where: 'type', 'cell'
-%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  {%- if cell_blocks.size > 1 -%}
    <div
      id="CollageSlider-{{ section.id }}"
      class="dimayo-collage dimayo-collage--carousel"
      role="list"
      aria-label="{{ 'general.slider.name' | t }}"
    >
      {%- for block in cell_blocks -%}
        <div class="dimayo-collage__cell" role="listitem" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1500
              | image_tag: widths: '375, 750, 1100, 1500', sizes: '(min-width: 990px) 31vw, (min-width: 750px) 45vw, 78vw', draggable: false
            }}
          {%- else -%}
            <div class="dimayo-collage__placeholder">{{ block.settings.caption | default: 'Imagen del producto' }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="dimayo-collage dimayo-collage--1">
      {%- for block in cell_blocks -%}
        <div class="dimayo-collage__cell" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1500
              | image_tag: widths: '375, 750, 1100, 1500', sizes: '100vw'
            }}
          {%- else -%}
            <div class="dimayo-collage__placeholder">{{ block.settings.caption | default: 'Imagen del producto' }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Collage de producto",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "cell",
      "name": "Imagen",
      "limit": 10,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Texto de placeholder (sin imagen)",
          "default": "Imagen del producto"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collage de producto",
      "blocks": [
        { "type": "cell" },
        { "type": "cell" },
        { "type": "cell" }
      ]
    }
  ]
}
{% endschema %}
