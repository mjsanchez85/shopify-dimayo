{% comment %}
  DIMAYO — Feature split (imagen + texto) para PDP. Ej. "Guardala":
  detalle funcional de un producto puntual (almacenamiento, cableado,
  mecanismo, etc.). Sin gradientes: el placeholder sin foto es un
  rectángulo Panel liso (PRD 2.4).
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="dimayo-split{% if section.settings.layout == 'text_first' %} dimayo-split--reverse{% endif %}">
      <div class="dimayo-split__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1500
            | image_tag: widths: '375, 750, 1100, 1500', sizes: '(min-width: 750px) 50vw, 100vw'
          }}
        {%- else -%}
          <div class="dimayo-collage__placeholder">{{ section.settings.image_placeholder | default: 'Imagen del producto' }}</div>
        {%- endif -%}
      </div>
      <div class="dimayo-split__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="rte">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Feature: imagen + texto",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Orden",
      "options": [
        { "value": "image_first", "label": "Imagen primero" },
        { "value": "text_first", "label": "Texto primero" }
      ],
      "default": "image_first"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "text",
      "id": "image_placeholder",
      "label": "Texto de placeholder (sin imagen)",
      "default": "Imagen del producto"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Encabezado",
      "default": "Guardala"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Un detalle funcional que resuelve algo puntual del uso diario.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "Feature: imagen + texto"
    }
  ]
}
{% endschema %}
